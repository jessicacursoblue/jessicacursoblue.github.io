# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nutriathlete

# Authentication
NEXTAUTH_SECRET=your-very-long-secret-key-minimum-32-characters-required-for-jwt

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NutriAthlete AI
NEXT_PUBLIC_API_URL=http://localhost:3000

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional: AI Gateway (for AI features)
AI_GATEWAY_API_KEY=optional_ai_gateway_key

# Environment
NODE_ENV=development
